########################################################################
# Eido Docker Compose 环境变量
#
# 使用前复制本文件为 .env 并填写实际值：
#   cp docker/.env.example docker/.env
########################################################################

# ======================== LLM 配置（二选一）========================

# --- MiniMax ---
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=sk-cp-7S6d1PnIR34p5eMr7hjp-WCCAAY1x65iWUFQj2qeH63Oc8Z4Nn2O8jBKaTT1P3FCXO6y3bH72hMQTJ4PQz4gG1mvipmgRt9xf_vMQPcronEhWqs7yWlICWQ
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_MODEL=
# ANTHROPIC_SMALL_FAST_MODEL=

# --- DeepSeek ---
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=your_deepseek_api_key
# ANTHROPIC_MODEL=deepseek-chat
# ANTHROPIC_SMALL_FAST_MODEL=deepseek-chat
# API_TIMEOUT_MS=600000
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# ======================== 端口与路径 =============================

# 宿主机端口（默认 80）
EIDO_PORT=80

# 宿主机 .claude 目录（包含 skills 等）
CLAUDE_DIR=~/.claude

# 日志目录（app/litellm/nginx 会自动创建子目录）
LOG_DIR=~/eido-logs

# ======================== 认证（可选）=============================
# 设为 False 并配合 --profile cas 启用 CAS 单点登录
AUTH_DISABLED=False
CAS_SERVER_URL=http://192.168.31.190:3331/cas/
CAS_SERVICE_URL=http://192.168.31.190/ai-eido/api/v1/auth/callback
FRONTEND_URL=http://192.168.31.190/ai-eido/
SESSION_SECRET_KEY=bce3920c6f5af337188623d3772de4d7dc520145fa5d2953e93934a4c579b9b6

# CAS 服务端口（默认 3331）
# CAS_PORT=3331
# CAS 测试用户（格式：user1::pwd1,user2::pwd2）
# CAS_USERS=casuser::Mellon,test1::123456,admin::admin123

# ======================== 沙箱多用户模式（profile=sandbox）===========
# 启用方式：
#   docker compose -f docker/docker-compose.yml --profile sandbox up -d
#
# 共享密钥（必填，gateway↔user 受信网关头校验，建议 32+ 字符随机串）
EIDO_GATEWAY_SECRET=ebfe491b7f7c7502dc8c32142f5bca8bb479539f20fb49b5d45f005ff9e90549
#
# user 容器镜像（gateway 通过 docker SDK 拉起）
# EIDO_USER_IMAGE=damaohongtu/eido-user:latest
#
# 闲置回收 TTL（秒），默认 15 min
# EIDO_SANDBOX_IDLE_TTL=900
#
# 单个 user 容器资源限额
# EIDO_USER_MEM=2g
# EIDO_USER_CPUS=1.0
# EIDO_USER_PIDS_LIMIT=500
EIDO_TRUST_GATEWAY=1
